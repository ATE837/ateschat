<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>NovaChat Pro</title>
    <link rel="manifest" href="data:application/json;base64,eyJuYW1lIjoiTm92YUNoYXQiLCJzaG9ydF9uYW1lIjoiTm92YUNoYXQiLCJzdGFydF91cmwiOiIuIiwiZGlzcGxheSI6InN0YW5kYWxvbmUiLCJiYWNrZ3JvdW5kX2NvbG9yIjoiIzExMTIxNCIsInRoZW1lX2NvbG9yIjoiIzExMTIxNCJ9">
    <meta name="theme-color" content="#111214">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    
    <!-- Firebase -->
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-storage-compat.js"></script>
    
    <style>
        :root {
            --bg: #111214;
            --bg-secondary: #1e1f22;
            --bg-tertiary: #2b2d31;
            --text: #f2f3f5;
            --text-muted: #949ba4;
            --primary: #5865f2;
            --primary-hover: #4752c4;
            --success: #23a55a;
            --warning: #faa61a;
            --danger: #ed4245;
            --online: #23a55a;
            --idle: #faa61a;
            --dnd: #ed4245;
            --offline: #747f8d;
        }

        [data-theme="light"] {
            --bg: #ffffff;
            --bg-secondary: #f2f3f5;
            --bg-tertiary: #e3e5e8;
            --text: #1e1f22;
            --text-muted: #4f5660;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--bg);
            color: var(--text);
            height: 100vh;
            height: 100dvh;
            overflow: hidden;
            user-select: none;
        }

        /* Auth Screen */
        #auth-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 20px;
        }

        .auth-card {
            background: var(--bg-secondary);
            padding: 40px;
            border-radius: 16px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
            animation: slideUp 0.5s ease;
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .auth-logo {
            font-size: 60px;
            text-align: center;
            margin-bottom: 10px;
        }

        .auth-title {
            font-size: 28px;
            font-weight: 700;
            text-align: center;
            margin-bottom: 8px;
        }

        .auth-subtitle {
            color: var(--text-muted);
            text-align: center;
            margin-bottom: 30px;
            font-size: 15px;
        }

        .auth-tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 25px;
            background: var(--bg-tertiary);
            padding: 5px;
            border-radius: 10px;
        }

        .tab-btn {
            flex: 1;
            padding: 12px;
            border: none;
            background: transparent;
            color: var(--text-muted);
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            transition: all 0.3s;
        }

        .tab-btn.active {
            background: var(--primary);
            color: white;
        }

        .admin-tab {
            flex: 0 0 50px;
        }

        .auth-input {
            width: 100%;
            padding: 14px 16px;
            margin-bottom: 12px;
            border: 1px solid var(--bg-tertiary);
            background: var(--bg);
            color: var(--text);
            border-radius: 8px;
            font-size: 15px;
            transition: all 0.3s;
        }

        .auth-input:focus {
            outline: none;
            border-color: var(--primary);
        }

        .auth-btn {
            width: 100%;
            padding: 14px;
            border: none;
            background: var(--primary);
            color: white;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .auth-btn:hover {
            background: var(--primary-hover);
            transform: translateY(-1px);
        }

        .auth-btn.secondary {
            background: var(--bg-tertiary);
            color: var(--text);
            margin-top: 10px;
        }

        .auth-btn.google {
            background: white;
            color: #757575;
            margin-top: 10px;
        }

        .auth-error {
            color: var(--danger);
            font-size: 13px;
            margin-top: 10px;
            text-align: center;
            display: none;
        }

        .admin-warning {
            background: rgba(237, 66, 69, 0.1);
            color: var(--danger);
            padding: 12px;
            border-radius: 8px;
            text-align: center;
            margin-bottom: 15px;
            font-weight: 600;
        }

        /* Main Layout */
        #main-layout {
            display: flex;
            height: 100vh;
            height: 100dvh;
        }

        #server-list {
            width: 72px;
            background: var(--bg);
            padding: 12px 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            overflow-y: auto;
            border-right: 1px solid var(--bg-tertiary);
        }

        .server-icon {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: var(--bg-secondary);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: 600;
            font-size: 18px;
            position: relative;
        }

        .server-icon:hover, .server-icon.active {
            border-radius: 16px;
            background: var(--primary);
        }

        .server-icon.active::before {
            content: '';
            position: absolute;
            left: -16px;
            width: 8px;
            height: 40px;
            background: var(--text);
            border-radius: 0 4px 4px 0;
        }

        .server-icon.home {
            background: var(--bg-secondary);
            margin-bottom: 8px;
            border-bottom: 2px solid var(--bg-tertiary);
            border-radius: 16px;
        }

        .add-server-btn, .discover-btn {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            border: 2px dashed var(--success);
            background: transparent;
            color: var(--success);
            font-size: 24px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
        }

        .add-server-btn:hover, .discover-btn:hover {
            background: var(--success);
            color: white;
            border-style: solid;
        }

        #channel-list {
            width: 240px;
            background: var(--bg-secondary);
            display: flex;
            flex-direction: column;
            border-right: 1px solid var(--bg-tertiary);
        }

        #channel-list-header {
            padding: 16px;
            border-bottom: 1px solid var(--bg-tertiary);
            font-weight: 700;
            font-size: 16px;
            box-shadow: 0 1px 0 rgba(0,0,0,0.1);
        }

        #channels {
            flex: 1;
            overflow-y: auto;
            padding: 8px;
        }

        .channel-item {
            padding: 8px 12px;
            margin-bottom: 2px;
            border-radius: 4px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--text-muted);
            font-size: 16px;
            transition: all 0.2s;
        }

        .channel-item:hover, .channel-item.active {
            background: var(--bg-tertiary);
            color: var(--text);
        }

        .channel-item::before {
            content: '#';
            font-size: 20px;
            font-weight: 300;
        }

        .add-channel-btn {
            margin: 8px;
            padding: 8px;
            border: none;
            background: transparent;
            color: var(--text-muted);
            cursor: pointer;
            border-radius: 4px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
        }

        .add-channel-btn:hover {
            color: var(--text);
            background: var(--bg-tertiary);
        }

        #channel-user-bar {
            padding: 12px;
            background: var(--bg-tertiary);
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
            margin-top: auto;
        }

        .user-avatar-small {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 14px;
            position: relative;
        }

        .status-dot {
            position: absolute;
            bottom: -2px;
            right: -2px;
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: var(--online);
            border: 3px solid var(--bg-tertiary);
        }

        #chat-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: var(--bg);
        }

        #chat-header {
            padding: 16px;
            border-bottom: 1px solid var(--bg-tertiary);
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 1px 0 rgba(0,0,0,0.1);
        }

        #channel-title {
            font-weight: 600;
            font-size: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        #header-buttons {
            display: flex;
            gap: 8px;
        }

        .call-btn, .invite-btn, .server-settings-btn {
            padding: 8px 12px;
            border: none;
            background: var(--bg-secondary);
            color: var(--text-muted);
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.2s;
        }

        .call-btn:hover, .invite-btn:hover, .server-settings-btn:hover {
            background: var(--bg-tertiary);
            color: var(--text);
        }

        #messages {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .message {
            display: flex;
            gap: 16px;
            padding: 4px 0;
            animation: fadeIn 0.3s;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .message-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            flex-shrink: 0;
            cursor: pointer;
        }

        .message-content {
            flex: 1;
            min-width: 0;
        }

        .message-header {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 4px;
        }

        .message-author {
            font-weight: 600;
            font-size: 16px;
            cursor: pointer;
        }

        .message-time {
            color: var(--text-muted);
            font-size: 12px;
        }

        .message-text {
            color: var(--text);
            font-size: 15px;
            line-height: 1.4;
            word-wrap: break-word;
        }

        #chat-input-wrap {
            padding: 16px;
            display: flex;
            gap: 16px;
            align-items: center;
        }

        .attach-btn {
            width: 44px;
            height: 44px;
            border: none;
            background: var(--bg-secondary);
            color: var(--text-muted);
            border-radius: 50%;
            cursor: pointer;
            font-size: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
        }

        .attach-btn:hover {
            background: var(--bg-tertiary);
            color: var(--text);
        }

        #msg-input {
            flex: 1;
            padding: 12px 16px;
            border: none;
            background: var(--bg-secondary);
            color: var(--text);
            border-radius: 8px;
            font-size: 15px;
            outline: none;
        }

        #msg-input:focus {
            background: var(--bg-tertiary);
        }

        #send-btn {
            width: 44px;
            height: 44px;
            border: none;
            background: var(--primary);
            color: white;
            border-radius: 50%;
            cursor: pointer;
            font-size: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
        }

        #send-btn:hover {
            background: var(--primary-hover);
            transform: scale(1.05);
        }

        #members-panel {
            width: 240px;
            background: var(--bg-secondary);
            padding: 16px;
            border-left: 1px solid var(--bg-tertiary);
            overflow-y: auto;
        }

        .members-title {
            font-size: 12px;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            margin-bottom: 16px;
            letter-spacing: 0.5px;
        }

        .member-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 6px 8px;
            border-radius: 4px;
            cursor: pointer;
            margin-bottom: 2px;
            transition: all 0.2s;
        }

        .member-item:hover {
            background: var(--bg-tertiary);
        }

        /* Modals */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.8);
            z-index: 1000;
            align-items: center;
            justify-content: center;
            padding: 20px;
            backdrop-filter: blur(4px);
        }

        .modal.show {
            display: flex;
        }

        .modal-box {
            background: var(--bg-secondary);
            border-radius: 12px;
            width: 100%;
            max-width: 440px;
            max-height: 90vh;
            overflow: hidden;
            animation: modalIn 0.3s;
            box-shadow: 0 24px 48px rgba(0,0,0,0.4);
        }

        @keyframes modalIn {
            from { opacity: 0; transform: scale(0.9) translateY(20px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }

        .modal-header {
            padding: 20px;
            border-bottom: 1px solid var(--bg-tertiary);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-header h3 {
            font-size: 20px;
            font-weight: 700;
        }

        .modal-close {
            width: 36px;
            height: 36px;
            border: none;
            background: var(--bg-tertiary);
            color: var(--text-muted);
            border-radius: 50%;
            cursor: pointer;
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
        }

        .modal-close:hover {
            background: var(--danger);
            color: white;
        }

        .modal-body {
            padding: 20px;
            overflow-y: auto;
            max-height: 60vh;
        }

        .modal-input {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid var(--bg-tertiary);
            background: var(--bg);
            color: var(--text);
            border-radius: 8px;
            font-size: 15px;
            margin-bottom: 16px;
        }

        .modal-input:focus {
            outline: none;
            border-color: var(--primary);
        }

        .modal-cancel {
            width: 100%;
            padding: 12px;
            border: none;
            background: transparent;
            color: var(--text-muted);
            cursor: pointer;
            font-size: 14px;
            margin-top: 8px;
        }

        .modal-cancel:hover {
            color: var(--text);
        }

        /* Settings */
        .settings-section {
            margin-bottom: 24px;
        }

        .s-label {
            font-size: 12px;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            margin-bottom: 12px;
            letter-spacing: 0.5px;
        }

        .s-btn {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 8px;
            transition: all 0.2s;
        }

        .s-btn.blue {
            background: var(--primary);
            color: white;
        }

        .s-btn.blue:hover {
            background: var(--primary-hover);
        }

        .s-btn.red {
            background: var(--danger);
            color: white;
        }

        .s-btn.red:hover {
            background: #c03537;
        }

        .s-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid var(--bg-tertiary);
        }

        .toggle {
            position: relative;
            width: 44px;
            height: 24px;
        }

        .toggle input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .toggle-slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: var(--bg-tertiary);
            border-radius: 24px;
            transition: 0.3s;
        }

        .toggle-slider:before {
            position: absolute;
            content: "";
            height: 18px;
            width: 18px;
            left: 3px;
            bottom: 3px;
            background: white;
            border-radius: 50%;
            transition: 0.3s;
        }

        .toggle input:checked + .toggle-slider {
            background: var(--success);
        }

        .toggle input:checked + .toggle-slider:before {
            transform: translateX(20px);
        }

        /* Toast */
        .toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .toast {
            background: var(--bg-secondary);
            color: var(--text);
            padding: 16px 20px;
            border-radius: 8px;
            box-shadow: 0 8px 16px rgba(0,0,0,0.3);
            display: flex;
            align-items: center;
            gap: 12px;
            animation: slideRight 0.3s;
            min-width: 300px;
            border-left: 4px solid var(--primary);
        }

        @keyframes slideRight {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        .toast.success { border-left-color: var(--success); }
        .toast.error { border-left-color: var(--danger); }

        /* Loading */
        .loading {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: var(--bg);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            gap: 20px;
        }

        .spinner {
            width: 50px;
            height: 50px;
            border: 4px solid var(--bg-tertiary);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Mobile */
        @media (max-width: 768px) {
            #server-list {
                width: 60px;
            }
            
            #channel-list {
                position: absolute;
                left: 60px;
                top: 0;
                bottom: 0;
                z-index: 100;
                transform: translateX(-100%);
                transition: transform 0.3s;
            }
            
            #channel-list.show {
                transform: translateX(0);
            }
            
            #members-panel {
                display: none;
            }
            
            .server-icon.active::before {
                left: -12px;
                width: 4px;
            }
        }

        /* Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: var(--bg-tertiary);
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--text-muted);
        }
    </style>
</head>
<body>

    <!-- Loading -->
    <div class="loading" id="loading">
        <div class="spinner"></div>
        <p>Bağlanıyor...</p>
    </div>

    <!-- Auth -->
    <div id="auth-container" style="display: none;">
        <div class="auth-card">
            <div class="auth-logo">✨</div>
            <h1 class="auth-title">NovaChat</h1>
            <p class="auth-subtitle">Yıldızlar kadar parlak, anlık bağlantı.</p>
            
            <div class="auth-tabs">
                <button class="tab-btn active" onclick="showTab('login')">Giriş Yap</button>
                <button class="tab-btn" onclick="showTab('register')">Kayıt Ol</button>
            </div>

            <div id="form-login">
                <input type="email" class="auth-input" id="login-email" placeholder="E-posta adresiniz">
                <input type="password" class="auth-input" id="login-password" placeholder="Şifreniz">
                <button class="auth-btn" onclick="doLogin()">
                    <i class="fas fa-sign-in-alt"></i> Giriş Yap
                </button>
                <button class="auth-btn google" onclick="doGoogleLogin()">
                    <i class="fab fa-google"></i> Google ile Giriş
                </button>
                <p class="auth-error" id="login-error"></p>
            </div>

            <div id="form-register" style="display: none;">
                <input type="text" class="auth-input" id="reg-name" placeholder="Kullanıcı adınız">
                <input type="email" class="auth-input" id="reg-email" placeholder="E-posta adresiniz">
                <input type="password" class="auth-input" id="reg-password" placeholder="Şifre (en az 6 karakter)">
                <button class="auth-btn" onclick="doRegister()">
                    <i class="fas fa-user-plus"></i> Hesap Oluştur
                </button>
                <button class="auth-btn google" onclick="doGoogleLogin()">
                    <i class="fab fa-google"></i> Google ile Kayıt Ol
                </button>
                <p class="auth-error" id="reg-error"></p>
            </div>
        </div>
    </div>

    <!-- Main App -->
    <div id="main-layout" style="display: none;">
        <div id="server-list">
            <div class="server-icon home active" onclick="goHome()" title="Ana Sayfa">🏠</div>
            <div id="server-icons"></div>
            <button class="add-server-btn" onclick="showModal('modal-create')" title="Sunucu Ekle">+</button>
            <button class="discover-btn" onclick="showDiscover()" title="Keşfet">🌐</button>
        </div>

        <div id="channel-list">
            <div id="channel-list-header">Sunucu Adı</div>
            <div id="channels"></div>
            <button class="add-channel-btn" onclick="showModal('modal-add-channel')">＋ Kanal Ekle</button>
            
            <div id="channel-user-bar" onclick="showModal('modal-settings')">
                <div class="user-avatar-small" id="my-avatar">?</div>
                <span id="my-name">Kullanıcı</span>
                <span style="margin-left: auto;">⚙️</span>
            </div>
        </div>

        <div id="chat-area">
            <div id="chat-header">
                <span id="channel-title"># genel</span>
                <div id="header-buttons">
                    <button class="call-btn" onclick="startCall('voice')">📞</button>
                    <button class="call-btn" onclick="startCall('video')">📹</button>
                    <button class="invite-btn" onclick="showModal('modal-invite')">🔗 Davet</button>
                    <button class="server-settings-btn" onclick="showServerSettings()">⚙️</button>
                </div>
            </div>

            <div id="messages"></div>

            <div id="chat-input-wrap">
                <button class="attach-btn" onclick="document.getElementById('file-input').click()">📎</button>
                <input type="file" id="file-input" style="display: none;" onchange="handleFile(this)">
                <input type="text" id="msg-input" placeholder="Mesajınızı yazın..." onkeydown="if(event.key==='Enter') sendMessage()">
                <button id="send-btn" onclick="sendMessage()">➤</button>
            </div>
        </div>

        <div id="members-panel">
            <div class="members-title">Çevrimiçi — <span id="online-count">0</span></div>
            <div id="members-list"></div>
        </div>
    </div>

    <!-- Modals -->
    <div class="modal" id="modal-create">
        <div class="modal-box">
            <div class="modal-header">
                <h3>Sunucu Oluştur</h3>
                <button class="modal-close" onclick="hideModal('modal-create')">✕</button>
            </div>
            <div class="modal-body">
                <input type="text" class="modal-input" id="new-server-name" placeholder="Sunucu adı">
                <button class="auth-btn" onclick="createServer()">Oluştur</button>
                <button class="modal-cancel" onclick="hideModal('modal-create')">İptal</button>
            </div>
        </div>
    </div>

    <div class="modal" id="modal-add-channel">
        <div class="modal-box">
            <div class="modal-header">
                <h3>Kanal Ekle</h3>
                <button class="modal-close" onclick="hideModal('modal-add-channel')">✕</button>
            </div>
            <div class="modal-body">
                <input type="text" class="modal-input" id="new-channel-name" placeholder="Kanal adı">
                <button class="auth-btn" onclick="addChannel()">Ekle</button>
                <button class="modal-cancel" onclick="hideModal('modal-add-channel')">İptal</button>
            </div>
        </div>
    </div>

    <div class="modal" id="modal-invite">
        <div class="modal-box">
            <div class="modal-header">
                <h3>Davet Kodu</h3>
                <button class="modal-close" onclick="hideModal('modal-invite')">✕</button>
            </div>
            <div class="modal-body">
                <p style="color: var(--text-muted); margin-bottom: 12px;">Arkadaşlarınla paylaş:</p>
                <div class="modal-input" id="invite-code" style="background: var(--bg-tertiary); font-family: monospace;"></div>
                <button class="auth-btn" onclick="copyInvite()">Kopyala</button>
            </div>
        </div>
    </div>

    <div class="modal" id="modal-settings">
        <div class="modal-box">
            <div class="modal-header">
                <h3>Kullanıcı Ayarları</h3>
                <button class="modal-close" onclick="hideModal('modal-settings')">✕</button>
            </div>
            <div class="modal-body">
                <div class="settings-section">
                    <div class="s-label">Profil</div>
                    <input type="text" class="modal-input" id="settings-name" placeholder="Yeni kullanıcı adı">
                    <button class="s-btn blue" onclick="updateProfile()">Güncelle</button>
                </div>
                
                <div class="settings-section">
                    <div class="s-label">Tema</div>
                    <div class="s-row">
                        <span>Koyu Mod</span>
                        <label class="toggle">
                            <input type="checkbox" id="theme-toggle" checked onchange="toggleTheme()">
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                </div>
                
                <div class="settings-section">
                    <div class="s-label">Hesap</div>
                    <button class="s-btn red" onclick="doLogout()">Çıkış Yap</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container" id="toast-container"></div>

    <script>
        // ==================== FIREBASE CONFIG ====================
        // KENDİ BİLGİLERİNİZİ BURAYA YAPIŞTIRIN
        const firebaseConfig = {
            apiKey: "AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX",
            authDomain: "novachat-XXXXX.firebaseapp.com",
            projectId: "novachat-XXXXX",
            storageBucket: "novachat-XXXXX.appspot.com",
            messagingSenderId: "123456789",
            appId: "1:123456789:web:abcdef123456"
        };

        // ==================== GLOBAL VARIABLES ====================
        let app, auth, db, storage;
        let currentUser = null;
        let currentServer = null;
        let currentChannel = null;
        let demoMode = true;
        let servers = [];
        let channels = [];
        let messages = [];

        // ==================== INITIALIZATION ====================
        document.addEventListener('DOMContentLoaded', () => {
            // Initialize Firebase
            try {
                if (firebaseConfig.apiKey && !firebaseConfig.apiKey.includes('XXXXX')) {
                    app = firebase.initializeApp(firebaseConfig);
                    auth = firebase.auth();
                    db = firebase.firestore();
                    storage = firebase.storage();
                    demoMode = false;
                    
                    auth.onAuthStateChanged(handleAuthState);
                } else {
                    throw new Error('Firebase not configured');
                }
            } catch (e) {
                console.log('Demo mode active');
                setTimeout(() => {
                    hideLoading();
                    showAuth();
                }, 1000);
            }
        });

        function hideLoading() {
            document.getElementById('loading').style.display = 'none';
        }

        function handleAuthState(user) {
            hideLoading();
            if (user) {
                currentUser = user;
                initApp();
            } else {
                showAuth();
            }
        }

        // ==================== AUTH FUNCTIONS ====================
        function showAuth() {
            document.getElementById('auth-container').style.display = 'flex';
            document.getElementById('main-layout').style.display = 'none';
        }

        function showTab(tab) {
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            
            document.getElementById('form-login').style.display = tab === 'login' ? 'block' : 'none';
            document.getElementById('form-register').style.display = tab === 'register' ? 'block' : 'none';
            
            // Clear errors
            document.getElementById('login-error').style.display = 'none';
            document.getElementById('reg-error').style.display = 'none';
        }

        async function doLogin() {
            const email = document.getElementById('login-email').value;
            const password = document.getElementById('login-password').value;
            
            if (!email || !password) {
                showError('login-error', 'E-posta ve şifre giriniz');
                return;
            }

            if (demoMode) {
                currentUser = {
                    uid: 'demo',
                    email: email,
                    displayName: email.split('@')[0]
                };
                initApp();
                return;
            }

            try {
                await auth.signInWithEmailAndPassword(email, password);
            } catch (error) {
                showError('login-error', getErrorMessage(error.code));
            }
        }

        async function doRegister() {
            const name = document.getElementById('reg-name').value;
            const email = document.getElementById('reg-email').value;
            const password = document.getElementById('reg-password').value;
            
            if (!name || !email || !password) {
                showError('reg-error', 'Tüm alanları doldurun');
                return;
            }

            if (password.length < 6) {
                showError('reg-error', 'Şifre en az 6 karakter olmalı');
                return;
            }

            if (demoMode) {
                currentUser = {
                    uid: 'demo',
                    email: email,
                    displayName: name
                };
                initApp();
                return;
            }

            try {
                const cred = await auth.createUserWithEmailAndPassword(email, password);
                await cred.user.updateProfile({ displayName: name });
                await db.collection('users').doc(cred.user.uid).set({
                    name: name,
                    email: email,
                    createdAt: firebase.firestore.FieldValue.serverTimestamp()
                });
            } catch (error) {
                showError('reg-error', getErrorMessage(error.code));
            }
        }

        async function doGoogleLogin() {
            if (demoMode) {
                currentUser = {
                    uid: 'google_demo',
                    email: 'user@gmail.com',
                    displayName: 'Google User'
                };
                initApp();
                showToast('Google ile giriş yapıldı (Demo)', 'success');
                return;
            }

            const provider = new firebase.auth.GoogleAuthProvider();
            try {
                await auth.signInWithPopup(provider);
            } catch (error) {
                showError('login-error', getErrorMessage(error.code));
            }
        }

        function doLogout() {
            if (demoMode) {
                currentUser = null;
                hideModal('modal-settings');
                showAuth();
                return;
            }
            auth.signOut();
        }

        function getErrorMessage(code) {
            const messages = {
                'auth/invalid-email': 'Geçersiz e-posta adresi',
                'auth/user-disabled': 'Hesap devre dışı bırakılmış',
                'auth/user-not-found': 'Kullanıcı bulunamadı',
                'auth/wrong-password': 'Hatalı şifre',
                'auth/email-already-in-use': 'Bu e-posta zaten kullanımda',
                'auth/weak-password': 'Şifre çok zayıf',
                'auth/popup-closed-by-user': 'Giriş penceresi kapatıldı'
            };
            return messages[code] || 'Bir hata oluştu. Tekrar deneyin.';
        }

        function showError(id, message) {
            const el = document.getElementById(id);
            el.textContent = message;
            el.style.display = 'block';
            setTimeout(() => el.style.display = 'none', 5000);
        }

        // ==================== APP FUNCTIONS ====================
        function initApp() {
            document.getElementById('auth-container').style.display = 'none';
            document.getElementById('main-layout').style.display = 'flex';
            
            // Set user info
            const name = currentUser.displayName || currentUser.email.split('@')[0];
            document.getElementById('my-name').textContent = name;
            document.getElementById('my-avatar').textContent = name[0].toUpperCase();
            document.getElementById('settings-name').value = name;
            
            // Load demo data
            loadDemoServers();
            loadDemoChannels();
            loadDemoMessages();
            loadDemoMembers();
        }

        function loadDemoServers() {
            servers = [
                { id: 's1', name: 'Genel Sohbet', icon: '💬' },
                { id: 's2', name: 'Oyun', icon: '🎮' },
                { id: 's3', name: 'Müzik', icon: '🎵' }
            ];
            
            const container = document.getElementById('server-icons');
            container.innerHTML = '';
            
            servers.forEach(server => {
                const div = document.createElement('div');
                div.className = 'server-icon';
                div.textContent = server.icon;
                div.title = server.name;
                div.onclick = () => selectServer(server);
                container.appendChild(div);
            });
        }

        function selectServer(server) {
            currentServer = server;
            document.querySelectorAll('.server-icon').forEach(el => el.classList.remove('active'));
            event.target.classList.add('active');
            document.getElementById('channel-list-header').textContent = server.name;
            showToast(`${server.name} sunucusuna bağlanıldı`, 'success');
        }

        function goHome() {
            document.querySelectorAll('.server-icon').forEach(el => el.classList.remove('active'));
            document.querySelector('.server-icon.home').classList.add('active');
            document.getElementById('channel-list-header').textContent = 'Ana Sayfa';
        }

        function loadDemoChannels() {
            channels = [
                { id: 'c1', name: 'genel', server: 's1' },
                { id: 'c2', name: 'sohbet', server: 's1' },
                { id: 'c3', name: 'duyurular', server: 's1' }
            ];
            
            const container = document.getElementById('channels');
            container.innerHTML = '';
            
            channels.forEach(channel => {
                const div = document.createElement('div');
                div.className = 'channel-item';
                div.textContent = channel.name;
                div.onclick = () => selectChannel(channel);
                container.appendChild(div);
            });
        }

        function selectChannel(channel) {
            currentChannel = channel;
            document.querySelectorAll('.channel-item').forEach(el => el.classList.remove('active'));
            event.target.classList.add('active');
            document.getElementById('channel-title').textContent = '# ' + channel.name;
            loadDemoMessages();
        }

        function loadDemoMessages() {
            messages = [
                { id: 1, author: 'Ahmet', text: 'Merhaba herkese! 👋', time: '14:30', avatar: 'A' },
                { id: 2, author: 'Ayşe', text: 'Selam! Nasılsınız?', time: '14:32', avatar: 'A' },
                { id: 3, author: 'Mehmet', text: 'İyiyim, teşekkürler 😊', time: '14:35', avatar: 'M' }
            ];
            
            const container = document.getElementById('messages');
            container.innerHTML = '';
            
            messages.forEach(msg => {
                const div = document.createElement('div');
                div.className = 'message';
                div.innerHTML = `
                    <div class="message-avatar">${msg.avatar}</div>
                    <div class="message-content">
                        <div class="message-header">
                            <span class="message-author">${msg.author}</span>
                            <span class="message-time">${msg.time}</span>
                        </div>
                        <div class="message-text">${msg.text}</div>
                    </div>
                `;
                container.appendChild(div);
            });
            
            container.scrollTop = container.scrollHeight;
        }

        function loadDemoMembers() {
            const members = [
                { name: 'Ahmet', status: 'online' },
                { name: 'Ayşe', status: 'online' },
                { name: 'Mehmet', status: 'idle' },
                { name: 'Zeynep', status: 'dnd' }
            ];
            
            const container = document.getElementById('members-list');
            container.innerHTML = '';
            
            let onlineCount = 0;
            
            members.forEach(member => {
                if (member.status === 'online') onlineCount++;
                
                const div = document.createElement('div');
                div.className = 'member-item';
                
                const statusColors = {
                    online: '#23a55a',
                    idle: '#faa61a',
                    dnd: '#ed4245',
                    offline: '#747f8d'
                };
                
                div.innerHTML = `
                    <div class="user-avatar-small" style="background: ${statusColors[member.status]}">
                        ${member.name[0]}
                    </div>
                    <span>${member.name}</span>
                `;
                container.appendChild(div);
            });
            
            document.getElementById('online-count').textContent = onlineCount;
        }

        // ==================== CHAT FUNCTIONS ====================
        function sendMessage() {
            const input = document.getElementById('msg-input');
            const text = input.value.trim();
            
            if (!text) return;
            
            const container = document.getElementById('messages');
            const div = document.createElement('div');
            div.className = 'message';
            
            const name = currentUser.displayName || 'Sen';
            
            div.innerHTML = `
                <div class="message-avatar" style="background: var(--primary)">${name[0]}</div>
                <div class="message-content">
                    <div class="message-header">
                        <span class="message-author">${name}</span>
                        <span class="message-time">Şimdi</span>
                    </div>
                    <div class="message-text">${escapeHtml(text)}</div>
                </div>
            `;
            
            container.appendChild(div);
            container.scrollTop = container.scrollHeight;
            input.value = '';
            
            // Simulate reply
            setTimeout(() => {
                const replyDiv = document.createElement('div');
                replyDiv.className = 'message';
                replyDiv.innerHTML = `
                    <div class="message-avatar">B</div>
                    <div class="message-content">
                        <div class="message-header">
                            <span class="message-author">Bot</span>
                            <span class="message-time">Şimdi</span>
                        </div>
                        <div class="message-text">Mesajınız alındı! 👍</div>
                    </div>
                `;
                container.appendChild(replyDiv);
                container.scrollTop = container.scrollHeight;
            }, 2000);
        }

        function handleFile(input) {
            if (!input.files.length) return;
            const file = input.files[0];
            showToast(`Dosya yükleniyor: ${file.name}`, 'success');
            
            // Simulate file upload
            setTimeout(() => {
                const container = document.getElementById('messages');
                const div = document.createElement('div');
                div.className = 'message';
                
                const name = currentUser.displayName || 'Sen';
                
                div.innerHTML = `
                    <div class="message-avatar" style="background: var(--primary)">${name[0]}</div>
                    <div class="message-content">
                        <div class="message-header">
                            <span class="message-author">${name}</span>
                            <span class="message-time">Şimdi</span>
                        </div>
                        <div class="message-text">📎 ${file.name}</div>
                    </div>
                `;
                
                container.appendChild(div);
                container.scrollTop = container.scrollHeight;
            }, 1000);
            
            input.value = '';
        }

        // ==================== MODAL FUNCTIONS ====================
        function showModal(id) {
            document.getElementById(id).classList.add('show');
            
            if (id === 'modal-invite') {
                const code = 'nova-' + Math.random().toString(36).substring(2, 8).toUpperCase();
                document.getElementById('invite-code').textContent = code;
            }
        }

        function hideModal(id) {
            document.getElementById(id).classList.remove('show');
        }

        function createServer() {
            const name = document.getElementById('new-server-name').value;
            if (!name) {
                showToast('Sunucu adı giriniz', 'error');
                return;
            }
            
            const server = {
                id: 's' + Date.now(),
                name: name,
                icon: name[0].toUpperCase()
            };
            
            servers.push(server);
            
            const div = document.createElement('div');
            div.className = 'server-icon';
            div.textContent = server.icon;
            div.title = server.name;
            div.onclick = () => selectServer(server);
            document.getElementById('server-icons').appendChild(div);
            
            hideModal('modal-create');
            document.getElementById('new-server-name').value = '';
            showToast(`"${name}" sunucusu oluşturuldu`, 'success');
        }

        function addChannel() {
            const name = document.getElementById('new-channel-name').value;
            if (!name) {
                showToast('Kanal adı giriniz', 'error');
                return;
            }
            
            const channel = {
                id: 'c' + Date.now(),
                name: name,
                server: currentServer?.id || 's1'
            };
            
            channels.push(channel);
            
            const div = document.createElement('div');
            div.className = 'channel-item';
            div.textContent = name;
            div.onclick = () => selectChannel(channel);
            document.getElementById('channels').appendChild(div);
            
            hideModal('modal-add-channel');
            document.getElementById('new-channel-name').value = '';
            showToast(`#${name} kanalı oluşturuldu`, 'success');
        }

        function copyInvite() {
            const code = document.getElementById('invite-code').textContent;
            navigator.clipboard.writeText(code).then(() => {
                showToast('Davet kodu kopyalandı!', 'success');
            });
        }

        // ==================== SETTINGS FUNCTIONS ====================
        function updateProfile() {
            const newName = document.getElementById('settings-name').value;
            if (!newName) {
                showToast('İsim giriniz', 'error');
                return;
            }
            
            currentUser.displayName = newName;
            document.getElementById('my-name').textContent = newName;
            document.getElementById('my-avatar').textContent = newName[0].toUpperCase();
            showToast('Profil güncellendi', 'success');
            hideModal('modal-settings');
        }

        function toggleTheme() {
            const isDark = document.getElementById('theme-toggle').checked;
            document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
            showToast(isDark ? 'Koyu tema aktif' : 'Açık tema aktif', 'success');
        }

        // ==================== UTILITY FUNCTIONS ====================
        function showToast(message, type = 'success') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            
            const icon = type === 'success' ? '✓' : '✕';
            
            toast.innerHTML = `
                <span style="font-size: 20px;">${icon}</span>
                <span>${message}</span>
            `;
            
            container.appendChild(toast);
            
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(100%)';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function startCall(type) {
            showToast(`${type === 'voice' ? 'Sesli' : 'Görüntülü'} arama başlatılıyor...`, 'success');
        }

        function showDiscover() {
            showToast('Sunucu keşfet yakında geliyor', 'success');
        }

        function showServerSettings() {
            showToast('Sunucu ayarları yakında geliyor', 'success');
        }

        // Close modals on outside click
        document.querySelectorAll('.modal').forEach(modal => {
            modal.addEventListener('click', (e) => {
                if (e.target === modal) {
                    modal.classList.remove('show');
                }
            });
        });
    </script>
</body>
</html>
