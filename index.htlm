<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>NovaChat | Cyber Hub</title>
    
    <style>
        :root {
            --bg: #0b0c10;
            --panel: #1f2833;
            --accent: #66fcf1; /* Neon Cyan */
            --accent-dim: #45a29e;
            --text: #c5c6c7;
            --ghost: #e74c3c;
            --xp-color: #2ecc71;
        }

        body {
            margin: 0;
            background-color: var(--bg);
            color: var(--text);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow: hidden;
        }

        /* --- NEON UI ELEMENTS --- */
        #nova-header {
            height: 60px;
            background: var(--panel);
            display: flex;
            align-items: center;
            padding: 0 20px;
            border-bottom: 2px solid var(--accent);
            box-shadow: 0 0 15px rgba(102, 252, 241, 0.2);
        }

        .xp-container {
            flex: 1;
            margin-left: 20px;
            max-width: 200px;
        }

        .xp-bar {
            height: 10px;
            background: #111;
            border-radius: 5px;
            border: 1px solid var(--accent-dim);
            overflow: hidden;
        }

        #xp-fill {
            width: 0%;
            height: 100%;
            background: linear-gradient(90deg, var(--accent), var(--xp-color));
            box-shadow: 0 0 8px var(--accent);
            transition: width 0.5s;
        }

        /* --- CHAT AREA --- */
        #main-container {
            display: flex;
            height: calc(100vh - 60px);
        }

        #sidebar {
            width: 260px;
            background: #111;
            border-right: 1px solid #333;
            display: flex;
            flex-direction: column;
        }

        #chat-window {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: url('https://www.transparenttextures.com/patterns/carbon-fibre.png');
        }

        #messages {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .msg {
            background: rgba(31, 40, 51, 0.8);
            padding: 10px 15px;
            border-radius: 8px;
            max-width: 70%;
            border-left: 3px solid var(--accent);
        }

        /* Hayalet Mesaj Animasyonu */
        .msg.ghost {
            border-left-color: var(--ghost);
            animation: dissolve 10s forwards;
        }

        @keyframes dissolve {
            80% { opacity: 1; }
            100% { opacity: 0; transform: translateY(-10px); display: none; }
        }

        /* --- INPUT AREA --- */
        #input-area {
            padding: 20px;
            background: var(--panel);
            display: flex;
            gap: 10px;
            align-items: center;
        }

        input[type="text"] {
            flex: 1;
            background: #0b0c10;
            border: 1px solid var(--accent-dim);
            padding: 12px;
            color: #fff;
            border-radius: 5px;
            outline: none;
        }

        input[type="text"]:focus {
            border-color: var(--accent);
            box-shadow: 0 0 10px rgba(102, 252, 241, 0.3);
        }

        button {
            background: var(--accent);
            color: #0b0c10;
            border: none;
            padding: 10px 20px;
            border-radius: 5px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover {
            box-shadow: 0 0 15px var(--accent);
        }

        /* NovaRadio */
        #radio-bar {
            background: #000;
            color: var(--accent);
            font-size: 12px;
            padding: 5px;
            text-align: center;
            border-bottom: 1px solid #222;
        }
    </style>
</head>
<body>

    <div id="radio-bar">
        <marquee>📡 NovaRadio: Free Fire OB52 Güncellemesi Yaklaşıyor! | Seviye atlamak için mesaj gönder.</marquee>
    </div>

    <header id="nova-header">
        <h2 style="color: var(--accent); margin: 0;">NOVACHAT</h2>
        <div class="xp-container">
            <div style="font-size: 10px; margin-bottom: 2px;">LVL: <span id="lvl-txt">1</span></div>
            <div class="xp-bar"><div id="xp-fill"></div></div>
        </div>
        <div style="margin-left: auto; display: flex; align-items: center; gap: 15px;">
            <label style="font-size: 12px;">👻 Ghost Mode</label>
            <input type="checkbox" id="ghost-toggle">
            <button onclick="location.reload()">Çıkış</button>
        </div>
    </header>

    <div id="main-container">
        <div id="sidebar">
            <div style="padding: 20px; border-bottom: 1px solid #333;">
                <h4>Kanallar</h4>
                <div style="color: var(--accent);"># genel-chat</div>
                <div style="margin-top:10px;"># nova-farm</div>
            </div>
            <div style="padding: 20px;">
                <h4>Aktif Üyeler</h4>
                <div id="user-list">✨ Sistem Botu</div>
            </div>
        </div>

        <main id="chat-window">
            <div id="messages">
                <div class="msg"><b>NovaBot:</b> Hoş geldin! NovaChat dünyasına adım attın. 🚀</div>
            </div>
            <div id="input-area">
                <input type="text" id="user-input" placeholder="Mesajını buraya yaz..." onkeypress="handleEnter(event)">
                <button onclick="sendMsg()">GÖNDER</button>
            </div>
        </main>
    </div>

    <script>
        let xp = 0;
        let lvl = 1;

        // Mesaj Gönderme
        function sendMsg() {
            const input = document.getElementById('user-input');
            const ghostMode = document.getElementById('ghost-toggle').checked;
            const text = input.value.trim();

            if (text === "") return;

            renderMessage("Sen", text, ghostMode);
            processBotCommands(text);
            updateXP(10);
            
            input.value = "";
        }

        function renderMessage(user, text, isGhost) {
            const msgDiv = document.createElement('div');
            msgDiv.className = isGhost ? 'msg ghost' : 'msg';
            msgDiv.innerHTML = `<b>${user}:</b> ${text}`;
            
            const container = document.getElementById('messages');
            container.appendChild(msgDiv);
            container.scrollTop = container.scrollHeight;
        }

        // NovaBot Komutları
        function processBotCommands(text) {
            const cmd = text.toLowerCase();
            
            if (cmd === "/zar") {
                const res = Math.floor(Math.random() * 6) + 1;
                setTimeout(() => renderMessage("NovaBot 🤖", `🎲 Zar sonucu: ${res}`), 500);
            } 
            else if (cmd.includes("ff") || cmd.includes("güncelleme")) {
                setTimeout(() => renderMessage("NovaBot 🤖", "📢 Free Fire OB52 güncellemesi için geri sayım başladı! Portalı takip et."), 800);
            }
            else if (cmd.includes("farm") || cmd.includes("nova farm")) {
                setTimeout(() => renderMessage("NovaBot 🤖", "🚜 NOVA FARM projen harika gidiyor! Chaten puan toplayıp çiftliğini geliştirebilirsin."), 800);
            }
        }

        // XP & Level Sistemi
        function updateXP(amount) {
            xp += amount;
            if (xp >= 100) {
                xp = 0;
                lvl++;
                renderMessage("Sistem ✨", `🎉 TEBRİKLER! Seviye atladın: Seviye ${lvl}`);
            }
            
            document.getElementById('xp-fill').style.width = xp + "%";
            document.getElementById('lvl-txt').innerText = lvl;
        }

        function handleEnter(e) {
            if (e.key === 'Enter') sendMsg();
        }
    </script>
</body>
</html>
